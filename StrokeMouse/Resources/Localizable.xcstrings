    "permissions.accessibilityFooter": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Required to observe mouse buttons and inject keyboard / window actions. If the system toggle is on but this page still shows denied, remove StrokeMouse from Privacy → Accessibility, quit the app, reopen it, then enable it again (common after re-signing)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于监听鼠标按键，以及注入快捷键 / 窗口操作。若系统开关已打开但此处仍显示未授权：请在「隐私与安全性 → 辅助功能」中移除 StrokeMouse，完全退出应用后重新打开，再重新打开开关（更换签名证书后常见）。"
          }
        }
      }
