    "gestures.sidebarRemoveAppConfirmMessage": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove “%@” from the sidebar?\n• %d gesture(s) only for this app will be deleted.\n• %d multi-app gesture(s) will keep their other apps."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定从侧边栏移除“%@”吗？\n• 仅作用于该应用的 %d 条手势将被删除。\n• %d 条同时作用于多个应用的手势只会取消本应用，不影响其他应用。"
          }
        }
      }
