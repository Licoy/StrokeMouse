    "gestureTest.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a trigger, then draw with the left mouse button. This uses the production matcher but never runs an action or applies app scope."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择触发键后使用鼠标左键绘制。这里使用正式匹配算法，但绝不会执行动作，也不受应用范围限制。"
          }
        }
      }
    },
