    "general.hideChromeFooter": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When the menu bar icon is hidden, open StrokeMouse again from the Dock, Launchpad, or Spotlight to show Settings. If both icons are hidden, use Spotlight or Launchpad. Quit from General settings or press ⌘Q while Settings is frontmost."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏菜单栏图标后，可通过 Dock、启动台或聚焦搜索再次打开 StrokeMouse 进入设置。若同时隐藏 Dock 图标，请使用聚焦搜索或启动台打开。退出请到「通用」设置，或在设置窗口前台时按 ⌘Q。"
          }
        }
      }
    },
    "general.quitApp": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quit StrokeMouse"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退出 StrokeMouse"
          }
        }
      }
    },
    "general.quitAppFooter": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Needed when the menu bar icon is hidden. You can also press ⌘Q while this window is frontmost."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏菜单栏图标时请从这里完全退出应用；设置窗口在前台时也可按 ⌘Q。"
          }
        }
      }
