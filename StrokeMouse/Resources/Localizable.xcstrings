    "onboarding.welcome.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold a mouse button, draw a stroke, release — your custom action fires."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住鼠标按键，画出轨迹，松开即可触发自定义动作。"
          }
        }
      }
    },
    "onboarding.permission.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Accessibility"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启辅助功能权限"
          }
        }
      }
    },
    "onboarding.permission.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "StrokeMouse needs Accessibility to listen for mouse buttons and run gestures. We’ll open System Settings and show a helper so you can drag the app into the list."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "StrokeMouse 需要「辅助功能」权限才能监听鼠标按键并执行手势。我们会打开系统设置，并显示悬浮辅助面板，方便你把应用拖入列表。"
          }
        }
      }
    },
    "onboarding.permission.granted": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility is granted. Gesture listening can start."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能已授权，可以开始手势监听。"
          }
        }
      }
    },
