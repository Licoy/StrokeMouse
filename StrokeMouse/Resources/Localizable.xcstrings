    "general.doubleHideMessage": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "StrokeMouse will keep running in the background with no Dock or menu bar icon. Open it again from Spotlight or Launchpad to reach Settings, and quit from General settings (or ⌘Q while Settings is open)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "StrokeMouse 将在后台继续运行，且没有 Dock 与菜单栏图标。请通过聚焦搜索或启动台再次打开以进入设置；退出请到「通用」设置（或在设置打开时按 ⌘Q）。"
          }
        }
      }
    },
